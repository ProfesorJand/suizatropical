---
import Header from '../components/Header/Header.jsx';
import { ClientRouter } from 'astro:transitions';

const { title = "Suiza Tropical" } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/suizatropical/lombriz.webp" />
		<link rel="preload" href="/suizatropical/logo.png" as="image" fetchpriority="high" />
		<meta name="generator" content={Astro.generator} />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		<title>{title}</title>
    <ClientRouter />
	</head>
	<body>
    <Header pathname={Astro.url.pathname} client:load/>
    <main>
      <slot />
    </main>
	</body>
</html>

<style is:global>
	:root {
    /* Color Palette - Premium Nature Concept */
    --color-green-100: #e8f5e9;
    --color-green-500: #4caf50;
    --color-green-700: #2e7d32;
    --color-green-900: #1b5e20;
    
    --color-red-100: #ffebee;
    --color-red-500: #f44336;
    --color-red-700: #c62828;
    
    --color-white: #ffffff;
    --color-beige: #fbf8f1;
    --color-gray-800: #2d3748;
    --color-gray-900: #1a202c;
    
    /* Semantic Colors */
    --bg-primary: var(--color-beige);
    --bg-secondary: var(--color-white);
    --text-primary: var(--color-gray-900);
    --text-secondary: var(--color-green-900);
    --accent-red: var(--color-red-700);
    --accent-green: var(--color-green-700);
    
    /* Layout */
    --height-header: 10vh;
    --height-body: 90vh;
    
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    color: var(--text-primary);
  }

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		overflow: hidden;
    background-color: var(--bg-primary);
	}
	a {
		color: var(--accent-green);
    text-decoration: none;
    transition: color 0.3s ease;
	}

  main {
		height: var(--height-body);
		display: flex;
		justify-content: center;
    scrollbar-gutter: stable;
    background-color: var(--bg-primary); 
    position: relative;
    z-index: 1;
  }
</style>
